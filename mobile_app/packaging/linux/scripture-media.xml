<?xml version="1.0" encoding="UTF-8"?>
<!-- Registers the *.smbundle file type so the player can be its default handler.
     Install to /usr/share/mime/packages/ then run: update-mime-database /usr/share/mime -->
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="application/x-smbundle">
    <comment>Scripture Media bundle</comment>
    <comment xml:lang="id">Paket Media Kitab Suci</comment>
    <!-- A .smbundle IS a gzip archive, so gzip magic-detection would otherwise
         win over the glob and the file would open in an archive manager. Declare
         it a subclass of gzip (so the more-specific type wins for *.smbundle) and
         give the glob a high weight to beat the gzip magic rule. -->
    <sub-class-of type="application/gzip"/>
    <glob pattern="*.smbundle" weight="80"/>
    <icon name="scripture-media-player"/>
  </mime-type>
</mime-info>
